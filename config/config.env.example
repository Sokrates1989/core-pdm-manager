# Core PDM Manager configuration.
# Copy to config/config.env and adjust values as needed.

# Whether to use uv backend in PDM.
USE_UV_BACKEND=true

# Whether to enable PDM install cache.
PDM_INSTALL_CACHE=true

# Whether to enable PDM parallel install.
PDM_PARALLEL_INSTALL=true

# Default targets generated by generate-dep-files scripts.
PDM_MANAGER_DEFAULT_TARGETS=pyproject.toml,pdm.lock

# Optional: default Python version if project does not define PYTHON_VERSION in .env.
PDM_MANAGER_DEFAULT_PYTHON_VERSION=3.13-slim

# --- Optional: External AI Provider Settings ---
# These are only used when --use-external-ai / -UseExternalAi is explicitly enabled.
# PDM_MANAGER_AI_PROVIDER_ENDPOINT=https://api.openai.com/v1/chat/completions
# PDM_MANAGER_AI_PROVIDER_MODEL=gpt-4o-mini
# PDM_MANAGER_AI_PROVIDER_API_KEY_ENV=OPENAI_API_KEY
# PDM_MANAGER_AI_PROVIDER_TIMEOUT_SECONDS=45
