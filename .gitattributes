* text=auto

# Shell scripts must stay LF so they run inside Linux containers.
*.sh text eol=lf

# PowerShell scripts stay CRLF for Windows hosts.
*.ps1 text eol=crlf

# Common source and config defaults normalized to LF.
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
